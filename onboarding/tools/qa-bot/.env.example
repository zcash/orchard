# Copy to .env and fill in your API key.
#
# The bot defaults to OpenRouter so any of the cheap aggregated
# providers can serve as the generation backend. To switch to a local
# server (LM Studio, Ollama, llama.cpp's --server, vLLM, ...), set
# QA_BOT_BASE_URL to the OpenAI-compatible endpoint of that server,
# QA_BOT_MODEL to the model name it exposes, and QA_BOT_API_KEY to
# any non-empty placeholder (most local servers ignore it).

QA_BOT_API_KEY=sk-or-v1-replace-me
QA_BOT_BASE_URL=https://openrouter.ai/api/v1
QA_BOT_MODEL=meta-llama/llama-3.3-70b-instruct

# Used to build absolute URLs for "Sources" citations.
QA_BOT_SITE_BASE=https://dannywillems.github.io/orchard

# Optional. Defaults assume the qa-bot lives at
# onboarding/tools/qa-bot/ inside an onboarding/ repo, with docs at
# onboarding/docs/. Override to lift this tool into another course.
# QA_BOT_DOCS_DIR=/absolute/path/to/onboarding/docs
# QA_BOT_DB_PATH=/absolute/path/to/onboarding/tools/qa-bot/data/qa-bot.db
